#!/bin/sh
. "$(dirname -- "$0")/_/husky.sh"

# Load nvm so WSL node/npx are used instead of Windows binaries
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"

echo "Checking git identity..."
GIT_NAME=$(git config user.name)
GIT_EMAIL=$(git config user.email)
REQUIRED_NAME="Mohammad Asjad"
REQUIRED_EMAIL="asjad.august@gmail.com"

if [ "$GIT_NAME" != "$REQUIRED_NAME" ]; then
  echo "❌ Error: Git user.name must be '$REQUIRED_NAME'. Current: '$GIT_NAME'"
  echo "Run: git config --local user.name \"$REQUIRED_NAME\""
  exit 1
fi

if [ "$GIT_EMAIL" != "$REQUIRED_EMAIL" ]; then
  echo "❌ Error: Git user.email must be '$REQUIRED_EMAIL'. Current: '$GIT_EMAIL'"
  echo "Run: git config --local user.email \"$REQUIRED_EMAIL\""
  exit 1
fi

echo "✅ Identity check passed!"

echo "Running pre-commit checks..."

# Run lint-staged
npx lint-staged

# Dead code detection (advisory — does not block commit)
echo "Running dead code check..."
npm run deadcode 2>/dev/null || echo "⚠️  Dead code detected. Run 'npm run deadcode' to see unused exports."

# Run tests
npm run test:backend

if [ $? -ne 0 ]; then
  echo "❌ Tests failed. Please fix before committing."
  exit 1
fi

echo "✅ Pre-commit checks passed!"