# PostgreSQL
POSTGRES_USER=bitcorp
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=bitcorp_prod

# JWT
JWT_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME

# CORS
DOMAIN=bitcorp.mohammadasjad.com
CORS_ORIGINS=https://bitcorp.mohammadasjad.com

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=CHANGE_ME

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@bitcorp.local
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME

# Webhook
WEBHOOK_SECRET=CHANGE_ME

# External APIs
DECOLECTA_API_TOKEN=CHANGE_ME

# NAS backup sync (optional)
NAS_SSH_TARGET=user@nas-ip:/path/to/backups
