{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "type-enum": [
      2,
      "always",
      [
        "feat",
        "fix",
        "docs",
        "style",
        "refactor",
        "perf",
        "test",
        "build",
        "ci",
        "chore",
        "revert"
      ]
    ],
    "scope-enum": [
      2,
      "always",
      [
        "equipment",
        "operators",
        "daily-reports",
        "scheduling",
        "cost-analysis",
        "projects",
        "auth",
        "core",
        "shared",
        "docs",
        "tests",
        "deps"
      ]
    ],
    "subject-max-length": [2, "always", 72],
    "body-max-line-length": [2, "always", 100]
  }
}