<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contrato de Alquiler N°{{contrato.numero_contrato}}</title>
    <style>{{{styles}}}</style>
</head>
<body>

    <!-- ── HEADER ──────────────────────────────────────────── -->
    <div class="header">
        <div class="header-logo">
            {{#if logo}}
            <img src="data:image/png;base64,{{logo}}" alt="Logo" />
            {{/if}}
        </div>
        <div class="header-title">
            <h1>Contrato de Alquiler de Equipo Mecánico</h1>
            <h2>CORP-GEM-F-001</h2>
        </div>
        <div class="header-meta">
            <table>
                <tr>
                    <td class="meta-label">N° Contrato</td>
                    <td>{{contrato.numero_contrato}}</td>
                </tr>
                <tr>
                    <td class="meta-label">Tipo</td>
                    <td>{{contrato.tipo}}</td>
                </tr>
                <tr>
                    <td class="meta-label">Estado</td>
                    <td>{{contrato.estado}}</td>
                </tr>
                <tr>
                    <td class="meta-label">Fecha</td>
                    <td>{{formatDate contrato.fecha_contrato}}</td>
                </tr>
            </table>
        </div>
    </div>

    <!-- ── PARTES DEL CONTRATO ──────────────────────────────── -->
    <div class="parties-section">
        <h3>Partes del Contrato</h3>
        <div class="parties-grid">
            <!-- ARRENDATARIO -->
            <div class="party-block">
                <div class="party-label">EL ARRENDATARIO</div>
                <div class="party-field">
                    <span class="label">Razón Social:</span>
                    <span class="value">{{arrendatario.razon_social}}</span>
                </div>
                <div class="party-field">
                    <span class="label">RUC:</span>
                    <span class="value">{{arrendatario.ruc}}</span>
                </div>
                <div class="party-field">
                    <span class="label">Representante:</span>
                    <span class="value">{{arrendatario.representante}}</span>
                </div>
                <div class="party-field">
                    <span class="label">Domicilio:</span>
                    <span class="value">{{arrendatario.domicilio}}</span>
                </div>
            </div>
            <!-- ARRENDADOR (PROVEEDOR) -->
            <div class="party-block">
                <div class="party-label">EL ARRENDADOR</div>
                <div class="party-field">
                    <span class="label">Razón Social:</span>
                    <span class="value">{{proveedor.razon_social}}</span>
                </div>
                <div class="party-field">
                    <span class="label">RUC:</span>
                    <span class="value">{{proveedor.ruc}}</span>
                </div>
                <div class="party-field">
                    <span class="label">Representante:</span>
                    <span class="value">{{proveedor.representante}}</span>
                </div>
                <div class="party-field">
                    <span class="label">Domicilio:</span>
                    <span class="value">{{proveedor.direccion}}</span>
                </div>
                <div class="party-field">
                    <span class="label">Teléfono:</span>
                    <span class="value">{{proveedor.telefono}}</span>
                </div>
            </div>
        </div>
    </div>

    <!-- ── DESCRIPCIÓN DEL EQUIPO ──────────────────────────── -->
    <div class="equipment-section">
        <h3>Cláusula 1 — Descripción del Equipo</h3>
        <div class="equipment-grid">
            <div class="eq-field">
                <span class="label">Código:</span>
                <span class="value">{{equipo.codigo}}</span>
            </div>
            <div class="eq-field">
                <span class="label">Marca:</span>
                <span class="value">{{equipo.marca}}</span>
            </div>
            <div class="eq-field">
                <span class="label">Modelo:</span>
                <span class="value">{{equipo.modelo}}</span>
            </div>
            <div class="eq-field">
                <span class="label">Placa:</span>
                <span class="value">{{equipo.placa}}</span>
            </div>
            <div class="eq-field">
                <span class="label">N° Serie:</span>
                <span class="value">{{equipo.numero_serie}}</span>
            </div>
            <div class="eq-field">
                <span class="label">N° Chasis:</span>
                <span class="value">{{equipo.numero_chasis}}</span>
            </div>
            <div class="eq-field">
                <span class="label">N° Motor:</span>
                <span class="value">{{equipo.numero_motor}}</span>
            </div>
            <div class="eq-field">
                <span class="label">Año Fab.:</span>
                <span class="value">{{equipo.anio_fabricacion}}</span>
            </div>
            <div class="eq-field">
                <span class="label">Doc. Acredita:</span>
                <span class="value">{{contrato.documento_acredita}}</span>
            </div>
        </div>
    </div>

    <!-- ── TÉRMINOS FINANCIEROS ─────────────────────────────── -->
    <div class="terms-section">
        <h3>Cláusula 5 — Condiciones Económicas</h3>
        <div class="terms-grid">
            <div class="term-row">
                <span class="label">Modalidad:</span>
                <span class="value">{{contrato.modalidad}}</span>
            </div>
            <div class="term-row">
                <span class="label">Moneda:</span>
                <span class="value">{{contrato.moneda}}</span>
            </div>
            <div class="term-row">
                <span class="label">Tipo de Tarifa:</span>
                <span class="value">{{contrato.tipo_tarifa}}</span>
            </div>
            <div class="term-row">
                <span class="label">Tarifa:</span>
                <span class="value">{{contrato.moneda}} {{formatCurrency contrato.tarifa}}</span>
            </div>
            <div class="term-row">
                <span class="label">Horas Incluidas:</span>
                <span class="value">{{contrato.horas_incluidas}}</span>
            </div>
            <div class="term-row">
                <span class="label">Penalidad x Exceso:</span>
                <span class="value">{{contrato.moneda}} {{formatCurrency contrato.penalidad_exceso}}</span>
            </div>
            <div class="term-row">
                <span class="label">Mínimo por:</span>
                <span class="value">{{contrato.minimo_por}}</span>
            </div>
            <div class="term-row">
                <span class="label">Cantidad Mínima:</span>
                <span class="value">{{contrato.cantidad_minima}}</span>
            </div>
        </div>
        <div style="margin-top:3mm;">
            <strong style="font-size:8pt;">Servicios Incluidos:</strong>
            <div class="included-services">
                <div class="service-item">
                    <span class="checkbox {{#if contrato.incluye_operador}}checked{{/if}}">{{#if contrato.incluye_operador}}✓{{/if}}</span>
                    Operador
                </div>
                <div class="service-item">
                    <span class="checkbox {{#if contrato.incluye_motor}}checked{{/if}}">{{#if contrato.incluye_motor}}✓{{/if}}</span>
                    Motor / Combustible
                </div>
                {{#if contrato.costo_adicional_motor}}
                <div class="service-item" style="margin-left:4mm; font-size:7.5pt; color:#555;">
                    Costo adicional motor: {{contrato.moneda}} {{formatCurrency contrato.costo_adicional_motor}}
                </div>
                {{/if}}
            </div>
        </div>
    </div>

    <!-- ── CLÁUSULAS PRINCIPALES ──────────────────────────── -->
    <div class="clauses-section">

        <!-- Cláusula 2 -->
        <div class="clause">
            <div class="clause-title">Cláusula 2 — Vigencia y Plazo</div>
            <div class="clause-body">
                El presente contrato tiene vigencia a partir del
                <span class="highlight">{{formatDate contrato.fecha_inicio}}</span>
                hasta el <span class="highlight">{{formatDate contrato.fecha_fin}}</span>.
                {{#if contrato.plazo_texto}}
                <br/>{{contrato.plazo_texto}}
                {{/if}}
            </div>
        </div>

        <!-- Cláusula 4 -->
        <div class="clause">
            <div class="clause-title">Cláusula 4 — Lugar de Ejecución y Jurisdicción</div>
            <div class="clause-body">
                {{#if contrato.jurisdiccion}}
                {{contrato.jurisdiccion}}
                {{else}}
                Las partes se someten a la jurisdicción de los tribunales correspondientes al domicilio del Arrendatario.
                {{/if}}
            </div>
        </div>

        <!-- Cláusula 6 — Pago -->
        <div class="clause">
            <div class="clause-title">Cláusula 6 — Condiciones de Pago</div>
            <div class="clause-body">
                El Arrendatario deberá realizar el pago de las valorizaciones aprobadas en un plazo máximo de
                <span class="highlight">30 días calendario</span> desde la presentación de la factura correspondiente.
                Los pagos se realizarán en <span class="highlight">{{contrato.moneda}}</span>.
            </div>
        </div>

        <!-- Cláusula 7 — Obligaciones del Arrendador -->
        <div class="clause">
            <div class="clause-title">Cláusula 7 — Obligaciones del Arrendador</div>
            <div class="clause-body">
                El Arrendador se obliga a: (1) Mantener el equipo operativo durante todo el período de contrato;
                (2) Contar con póliza TREC vigente durante toda la vigencia del contrato;
                (3) Mantener la documentación del operador y equipo vigente (SOAT, CITV, licencia);
                (4) Suministrar operador calificado si el contrato es modalidad Operada;
                (5) Reparar o reemplazar el equipo en caso de falla en un plazo máximo de 5 días calendario;
                (6) Proveer extintor, kit antiderrames y dispositivos de seguridad requeridos.
            </div>
        </div>

        <!-- Cláusula 8 — Obligaciones del Arrendatario -->
        <div class="clause">
            <div class="clause-title">Cláusula 8 — Obligaciones del Arrendatario</div>
            <div class="clause-body">
                El Arrendatario se obliga a: (1) Pagar oportunamente las valorizaciones aprobadas;
                (2) Brindar guardianía y condiciones adecuadas de trabajo;
                (3) Proveer el combustible necesario para la operación (si aplica según modalidad);
                (4) Emitir y aprobar los partes diarios dentro del plazo establecido.
            </div>
        </div>

        <!-- Cláusula 12 — Resolución -->
        {{#if contrato.motivo_resolucion}}
        <div class="clause">
            <div class="clause-title">Cláusula 12 — Resolución del Contrato</div>
            <div class="clause-body">
                Contrato rescindido el <span class="highlight">{{formatDate contrato.fecha_resolucion}}</span>.
                Motivo: {{contrato.motivo_resolucion}}.
                {{#if contrato.monto_liquidacion}}
                Monto de liquidación: <span class="highlight">{{contrato.moneda}} {{formatCurrency contrato.monto_liquidacion}}</span>.
                {{/if}}
            </div>
        </div>
        {{/if}}

    </div>

    <!-- ── CONDICIONES ESPECIALES ─────────────────────────── -->
    {{#if contrato.condiciones_especiales}}
    <div class="clause">
        <div class="clause-title">Condiciones Especiales</div>
        <div class="conditions-box">{{contrato.condiciones_especiales}}</div>
    </div>
    {{/if}}

    <!-- ── FIRMAS ─────────────────────────────────────────── -->
    <div class="signatures-section">
        <div class="signature-block">
            <div class="signature-line">
                <div class="sig-name">{{arrendatario.razon_social}}</div>
                <div class="sig-role">EL ARRENDATARIO</div>
                <div class="sig-ruc">RUC: {{arrendatario.ruc}}</div>
            </div>
        </div>
        <div class="signature-block">
            <div class="signature-line">
                <div class="sig-name">{{proveedor.razon_social}}</div>
                <div class="sig-role">EL ARRENDADOR</div>
                <div class="sig-ruc">RUC: {{proveedor.ruc}}</div>
            </div>
        </div>
    </div>

    <!-- ── FOOTER ─────────────────────────────────────────── -->
    <div class="doc-footer">
        CORP-GEM-F-001 | Contrato N°{{contrato.numero_contrato}} | Generado: {{fechaGeneracion}}
    </div>

</body>
</html>
