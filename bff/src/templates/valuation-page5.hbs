<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Valorización - Gastos de Obra</title>
    <style>{{{styles}}}</style>
</head>
<body>
    <div class="report-header-mini">
        <span class="page-title">GASTOS DE OBRA</span>
        <span class="valuation-id">VALORIZACIÓN N°{{valorizacion.numero_valorizacion}}</span>
    </div>
    
    <table class="info-table-compact">
        <tr>
            <td class="label-cell">Equipo:</td>
            <td class="value-cell">{{equipo.codigo_equipo}} - {{equipo.nombre}}</td>
            <td class="spacer-cell"></td>
            <td class="label-cell">Periodo:</td>
            <td class="value-cell">{{formatDate valorizacion.fecha_inicio}} al {{formatDate valorizacion.fecha_fin}}</td>
        </tr>
    </table>

    <table class="detail-table">
        <thead>
            <tr>
                <th>Fecha</th>
                <th>Proveedor</th>
                <th>Concepto</th>
                <th>Tipo Doc.</th>
                <th>N° Doc.</th>
                <th>Inc. IGV</th>
                <th>Importe S/IGV</th>
                <th>Importe C/IGV</th>
            </tr>
        </thead>
        <tbody>
            {{#each gastos_obra}}
            <tr>
                <td class="text-center">{{formatDate fecha_operacion}}</td>
                <td>{{proveedor}}</td>
                <td>{{concepto}}</td>
                <td class="text-center">{{tipo_documento}}</td>
                <td class="text-center">{{num_documento}}</td>
                <td class="text-center">{{incluye_igv}}</td>
                <td class="text-right">{{formatCurrency importe_sin_igv}}</td>
                <td class="text-right">{{formatCurrency importe}}</td>
            </tr>
            {{/each}}
        </tbody>
        <tfoot>
            <tr class="total-row">
                <td colspan="6" class="text-right bold">TOTALES:</td>
                <td class="text-right bold">{{formatCurrency total_gastos_sin_igv}}</td>
                <td class="text-right bold">{{formatCurrency total_gastos_con_igv}}</td>
            </tr>
        </tfoot>
    </table>

    <div class="page-footer">
        <div class="page-number">5 de 7</div>
        <div class="print-date">Impreso el {{formatDateTime fecha_impresion}}</div>
    </div>
</body>
</html>
