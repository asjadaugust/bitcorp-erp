<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Valorización N°{{valorizacion.numero_valorizacion}}</title>
    <style>
        {{{styles}}}
    </style>
</head>
<body>
    <!-- HEADER SECTION -->
    <div class="report-header">
        <div class="logo-container">
            <!-- Logo placeholder - replace with actual base64 encoded image -->
            <img src="data:image/png;base64,{{logo}}" alt="CCECC Logo" />
        </div>
        <div class="header-content">
            <div class="report-title">VALORIZACION N°{{valorizacion.numero_valorizacion}}</div>
            <div class="valuation-id">{{valorizacion.id_valorizacion}}</div>
            <div class="date-range">[Del: {{formatDate valorizacion.fecha_inicio}} Al {{formatDate valorizacion.fecha_fin}}]</div>
            <div class="report-subtitle">RESUMEN</div>
        </div>
    </div>

    <!-- EQUIPMENT & PROVIDER INFORMATION TABLE -->
    <table class="info-table avoid-break">
        <tbody>
            <!-- Row 1: RUC and Contract Number -->
            <tr>
                <td class="label-cell">Ruc:</td>
                <td class="value-cell">{{proveedor.ruc}}</td>
                <td class="spacer-cell"></td>
                <td class="label-cell-right">N° Contrato:</td>
                <td class="value-cell-right">{{contrato.numero_contrato}}</td>
            </tr>
            <!-- Row 2: Company Name and Document Type -->
            <tr>
                <td class="label-cell">Razón Social:</td>
                <td class="value-cell">{{proveedor.razon_social}}</td>
                <td class="spacer-cell"></td>
                <td class="label-cell-right">Tipo de Documento:</td>
                <td class="value-cell-right">{{contrato.tipo_documento}}</td>
            </tr>
            <!-- Row 3: Address and Modality -->
            <tr>
                <td class="label-cell">Dirección:</td>
                <td class="value-cell">{{proveedor.direccion}}</td>
                <td class="spacer-cell"></td>
                <td class="label-cell-right">Modalidad:</td>
                <td class="value-cell-right">{{contrato.modalidad}}</td>
            </tr>
            <!-- Row 4: Equipment Code and Rate Type -->
            <tr>
                <td class="label-cell">Código Equipo:</td>
                <td class="value-cell">{{equipo.codigo_equipo}}</td>
                <td class="spacer-cell"></td>
                <td class="label-cell-right">Tipo de Tarifa:</td>
                <td class="value-cell-right">{{contrato.tipo_tarifa}}</td>
            </tr>
            <!-- Row 5: Equipment Name and Rate -->
            <tr>
                <td class="label-cell">Equipo:</td>
                <td class="value-cell">{{equipo.nombre}}</td>
                <td class="spacer-cell"></td>
                <td class="label-cell-right">Tarifa:</td>
                <td class="value-cell-right">{{formatCurrency contrato.tarifa}}</td>
            </tr>
            <!-- Row 6: License Plate and Currency -->
            <tr>
                <td class="label-cell">Placa:</td>
                <td class="value-cell">{{equipo.placa}}</td>
                <td class="spacer-cell"></td>
                <td class="label-cell-right">Moneda:</td>
                <td class="value-cell-right">{{contrato.moneda}}</td>
            </tr>
            <!-- Row 7: Brand and Exchange Rate -->
            <tr>
                <td class="label-cell">Marca:</td>
                <td class="value-cell">{{equipo.marca}}</td>
                <td class="spacer-cell"></td>
                <td class="label-cell-right">Tasa de Cambio</td>
                <td class="value-cell-right">{{formatDecimal valorizacion.tipo_cambio 4}}</td>
            </tr>
            <!-- Row 8: Model and Minimum Per -->
            <tr>
                <td class="label-cell">Modelo:</td>
                <td class="value-cell">{{equipo.modelo}}</td>
                <td class="spacer-cell"></td>
                <td class="label-cell-right">Mínimo Por:</td>
                <td class="value-cell-right">{{contrato.minimo_por}}</td>
            </tr>
            <!-- Row 9: Meter Type and Minimum Quantity -->
            <tr>
                <td class="label-cell">Tipo:</td>
                <td class="value-cell">{{equipo.tipo_medidor}}</td>
                <td class="spacer-cell"></td>
                <td class="label-cell-right">Cantidad Mínima:</td>
                <td class="value-cell-right">{{formatDecimal contrato.cantidad_minima 2}}</td>
            </tr>
            <!-- Row 10: External Code -->
            <tr>
                <td class="label-cell">Cód. Externo:</td>
                <td class="value-cell">{{equipo.codigo_externo}}</td>
                <td class="spacer-cell"></td>
                <td class="label-cell-right"></td>
                <td class="value-cell-right"></td>
            </tr>
        </tbody>
    </table>

    <!-- FINANCIAL SUMMARY TABLE -->
    <table class="financial-table avoid-break">
        <thead>
            <tr>
                <th class="col-description">DESCRIPCIÓN</th>
                <th class="col-quantity">CANTIDAD</th>
                <th class="col-unit">UNID</th>
                <th class="col-price">P.U.</th>
                <th class="col-amount">IMPORTE</th>
            </tr>
        </thead>
        <tbody>
            <!-- VALUATION SECTION -->
            <tr>
                <td class="section-header" colspan="5">VALORIZACIÓN:</td>
            </tr>
            <tr>
                <td class="indent-1">Cantidad a Valorizar:</td>
                <td class="align-right">{{formatDecimal financiero.cantidad 2}}</td>
                <td class="align-center">{{financiero.unidad_medida}}</td>
                <td class="align-right">{{formatCurrency financiero.precio_unitario}}</td>
                <td class="align-right">{{formatCurrency financiero.valorizacion_bruta}}</td>
            </tr>
            
            <!-- DISCOUNTS SECTION -->
            <tr>
                <td class="section-header" colspan="5">DESCUENTOS:</td>
            </tr>
            <tr>
                <td class="indent-1">Combustible:</td>
                <td class="align-right">{{formatDecimal financiero.cantidad_combustible 2}}</td>
                <td class="align-center">gln</td>
                <td class="align-right">{{formatCurrency financiero.precio_combustible}}</td>
                <td class="align-right">{{formatCurrency financiero.importe_combustible}}</td>
            </tr>
            <tr>
                <td class="indent-1">Manipuleo de Combustible:</td>
                <td class="align-right">{{formatDecimal financiero.cantidad_combustible 2}}</td>
                <td class="align-center">gln</td>
                <td class="align-right">{{formatCurrency financiero.precio_manipuleo_combustible}}</td>
                <td class="align-right">{{formatCurrency financiero.importe_manipuleo_combustible}}</td>
            </tr>
            <tr>
                <td class="indent-1">Gastos en Obra:</td>
                <td class="align-right"></td>
                <td class="align-center"></td>
                <td class="align-right"></td>
                <td class="align-right">{{formatCurrency financiero.importe_gasto_obra}}</td>
            </tr>
            <tr>
                <td class="indent-1">Amortización por Adelantos:</td>
                <td class="align-right"></td>
                <td class="align-center"></td>
                <td class="align-right"></td>
                <td class="align-right">{{formatCurrency financiero.importe_adelanto}}</td>
            </tr>
            <tr>
                <td class="indent-1">Exceso de Combustible:</td>
                <td class="align-right"></td>
                <td class="align-center"></td>
                <td class="align-right"></td>
                <td class="align-right">{{formatCurrency financiero.importe_exceso_combustible}}</td>
            </tr>
            
            <!-- NET VALUATION -->
            <tr class="total-row">
                <td colspan="4" class="align-right bold">VALORIZACIÓN NETA</td>
                <td class="align-right bold">{{formatCurrency financiero.valorizacion_neta}}</td>
            </tr>
            
            <!-- IGV (TAX) -->
            <tr>
                <td colspan="4" class="align-right">I.G.V. 18%</td>
                <td class="align-right">{{formatCurrency financiero.igv}}</td>
            </tr>
            
            <!-- FINAL TOTAL -->
            <tr class="final-total-row">
                <td colspan="4" class="align-right bold">NETO A FACTURAR</td>
                <td class="align-right bold">{{formatCurrency financiero.neto_facturar}}</td>
            </tr>
        </tbody>
    </table>

    <!-- PAGE FOOTER -->
    <div class="page-footer">
        <div class="page-number">1 de 7</div>
        <div class="generation-date">Impreso el {{formatDateTime fechaImpresion}}</div>
    </div>
</body>
</html>
