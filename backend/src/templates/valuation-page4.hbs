<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Valorización - Exceso de Combustible</title>
    <style>{{{styles}}}</style>
</head>
<body>
    <div class="report-header-mini">
        <span class="page-title">EXCESO DE COMBUSTIBLE</span>
        <span class="valuation-id">VALORIZACIÓN N°{{valorizacion.numero_valorizacion}}</span>
    </div>
    
    <table class="info-table-compact">
        <tr>
            <td class="label-cell">Equipo:</td>
            <td class="value-cell">{{equipo.codigo_equipo}} - {{equipo.nombre}}</td>
            <td class="spacer-cell"></td>
            <td class="label-cell">Periodo:</td>
            <td class="value-cell">{{formatDate valorizacion.fecha_inicio}} al {{formatDate valorizacion.fecha_fin}}</td>
        </tr>
    </table>

    {{#if exceso_combustible}}
    <table class="detail-table">
        <tbody>
            <tr>
                <td class="label-cell bold">Consumo Total de Combustible:</td>
                <td class="text-right">{{formatNumber exceso_combustible.consumo_combustible 2}} Gal</td>
            </tr>
            <tr>
                <td class="label-cell bold">Tipo Medidor:</td>
                <td>{{exceso_combustible.tipo_horo_odo}}</td>
            </tr>
            <tr>
                <td class="label-cell bold">Lectura Inicial:</td>
                <td class="text-right">{{formatNumber exceso_combustible.inicio 2}}</td>
            </tr>
            <tr>
                <td class="label-cell bold">Lectura Final:</td>
                <td class="text-right">{{formatNumber exceso_combustible.final 2}}</td>
            </tr>
            <tr>
                <td class="label-cell bold">Total Trabajado:</td>
                <td class="text-right">{{formatNumber exceso_combustible.total 2}} H</td>
            </tr>
            <tr>
                <td class="label-cell bold">Rendimiento Estándar:</td>
                <td class="text-right">{{formatNumber exceso_combustible.rendimiento 4}} Gal/H</td>
            </tr>
            <tr>
                <td class="label-cell bold">Ratio de Control:</td>
                <td class="text-right">{{formatNumber exceso_combustible.ratio_control 4}} Gal/H</td>
            </tr>
            <tr>
                <td class="label-cell bold">Diferencia:</td>
                <td class="text-right">{{formatNumber exceso_combustible.diferencia 2}} Gal</td>
            </tr>
            <tr class="highlight-row">
                <td class="label-cell bold">Exceso de Combustible:</td>
                <td class="text-right bold">{{formatNumber exceso_combustible.exceso_combustible 2}} Gal</td>
            </tr>
            <tr>
                <td class="label-cell bold">Precio Unitario:</td>
                <td class="text-right">{{formatCurrency exceso_combustible.precio_unitario}}</td>
            </tr>
            <tr class="total-row">
                <td class="label-cell bold">IMPORTE EXCESO:</td>
                <td class="text-right bold">{{formatCurrency exceso_combustible.importe_exceso_combustible}}</td>
            </tr>
            {{#if exceso_combustible.observaciones}}
            <tr>
                <td class="label-cell bold">Observaciones:</td>
                <td>{{exceso_combustible.observaciones}}</td>
            </tr>
            {{/if}}
        </tbody>
    </table>
    {{else}}
    <div class="no-data-message">
        <p>No se registró exceso de combustible en este periodo.</p>
    </div>
    {{/if}}

    <div class="page-footer">
        <div class="page-number">4 de 7</div>
        <div class="print-date">Impreso el {{formatDateTime fecha_impresion}}</div>
    </div>
</body>
</html>
