# Database
DATABASE_URL=postgresql+asyncpg://bitcorp:dev_password_change_me@postgres:5432/bitcorp_dev
DB_HOST=postgres
DB_PORT=5432
POSTGRES_DB=bitcorp_dev
POSTGRES_USER=bitcorp
POSTGRES_PASSWORD=dev_password_change_me

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=dev_jwt_secret_change_in_production
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_production
JWT_EXPIRES_MINUTES=15
JWT_REFRESH_EXPIRES_DAYS=7

# Server
PORT=3410
ENVIRONMENT=development
LOG_LEVEL=debug

# CORS
CORS_ORIGINS=http://localhost:3420,http://localhost:4200,http://127.0.0.1:3420,http://127.0.0.1:4200

# Email (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@bitcorp.com
SMTP_PASSWORD=change_me
SMTP_FROM=noreply@bitcorp.com
EMAIL_LOG_ONLY=true

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=/tmp/uploads
