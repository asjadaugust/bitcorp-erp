{
  "name": "bitcorp-erp-backend",
  "version": "1.0.0",
  "description": "Bitcorp ERP Backend - Node.js TypeScript API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "typeorm": "typeorm-ts-node-commonjs",
    "migrate": "npm run typeorm migration:run -- -d src/config/database.config.ts",
    "migrate:revert": "npm run typeorm migration:revert -- -d src/config/database.config.ts",
    "migrate:create": "npm run typeorm migration:create",
    "seed:typeorm": "ts-node src/database/seeders/index.ts",
    "db:reset": "npm run migrate:revert && npm run migrate && npm run seed:typeorm",
    "migrate:prod": "typeorm migration:run -d dist/config/database.config.js",
    "schema:drop:prod": "typeorm schema:drop -d dist/config/database.config.js"
  },
  "dependencies": {
    "@types/multer": "^2.0.0",
    "@types/nodemailer": "^7.0.5",
    "@types/pdfkit": "^0.17.3",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-async-handler": "^1.2.0",
    "fastify": "^4.25.1",
    "handlebars": "^4.7.8",
    "helmet": "^7.2.0",
    "json2csv": "^5.0.7",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.12",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.17.2",
    "pg": "^8.16.3",
    "puppeteer": "^24.34.0",
    "redis": "^4.7.1",
    "sequelize": "^6.37.7",
    "typeorm": "^0.3.27",
    "uuid": "^9.0.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/handlebars": "^4.0.40",
    "@types/jest": "^29.5.11",
    "@types/json2csv": "^5.0.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.15.6",
    "@types/puppeteer": "^5.4.7",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
